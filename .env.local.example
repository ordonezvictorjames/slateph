# Supabase Configuration
# Get these values from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Developer Network Monitor - Supabase Management API
# Generate a Personal Access Token at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-personal-access-token
# Your project ref (the subdomain part of your Supabase URL)
SUPABASE_PROJECT_REF=your-project-ref

# Optional: Analytics (uncomment if using)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Error Tracking (uncomment if using Sentry)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# Development only (uncomment for debugging)
# NEXT_PUBLIC_DEBUG=true
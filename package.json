{
  "name": "slate-lms-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "A modern Learning Management System built with Next.js, React, and Supabase",
  "keywords": [
    "lms",
    "education",
    "nextjs",
    "react",
    "supabase",
    "learning"
  ],
  "author": "Slate Team",
  "license": "MIT",
  "homepage": "https://github.com/yourusername/slate-lms",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/slate-lms.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/slate-lms/issues"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "cross-env ANALYZE=true next build",
    "clean": "rm -rf .next out node_modules/.cache",
    "prepare": "husky install || true",
    "build:safe": "cross-env NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-key next build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.1.1",
    "@lottiefiles/dotlottie-react": "^0.18.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.39.3",
    "@vercel/speed-insights": "^1.3.1",
    "dotenv": "^17.2.3",
    "lottie-react": "^2.4.1",
    "next": "^15.1.6",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.24",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "^15.1.6",
    "husky": "^8.0.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^15.2.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "Chrome >= 90",
      "Firefox >= 88",
      "Safari >= 14",
      "Edge >= 90"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
